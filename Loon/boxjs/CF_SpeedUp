{
  "id": "CF_SpeedUp_Sub",
  "name": "CF 优选中心订阅",
  "description": "专为 Loon 打造的 CF 反代优选调度中心，提供可视化参数配置。",
  "author": "@Lee",
  "icon": "https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Cloudflare.png",
  "repo": "https://github.com/cocktai1/Rules",
  "apps": [
    {
      "id": "CF_SpeedUp",
      "name": "CF 优选中心",
      "keys": [
        "@CF_SpeedUp.token",
        "@CF_SpeedUp.domains",
        "@CF_SpeedUp.ip_url"
      ],
      "descs_html": [
        "<h4 align=\"center\">CF 终极优选调度中心</h4>",
        "<p align=\"center\">请在此处填写你的参数，点击底部保存后，Loon 脚本会自动读取。</p>"
      ],
      "settings": [
        {
          "id": "@CF_SpeedUp.token",
          "name": "GitHub Token",
          "val": "",
          "type": "text",
          "placeholder": "ghp_xxxxxx...",
          "desc": "必填：填入 ghp_ 开头的 Personal Access Token"
        },
        {
          "id": "@CF_SpeedUp.domains",
          "name": "加速域名",
          "val": "",
          "type": "text",
          "placeholder": "emby.abc.com, nas.abc.com",
          "desc": "必填：多个域名请用英文半角逗号分隔"
        },
        {
          "id": "@CF_SpeedUp.ip_url",
          "name": "自定义 IP 源库",
          "val": "https://cdn.jsdelivr.net/gh/ymyuuu/IPDB@main/bestcf.txt",
          "type": "text",
          "placeholder": "留空则使用默认库",
          "desc": "可选：留空则使用默认高可用库，也可填入你的 Sub-Store 链接"
        }
      ],
      "author": "@CodeMaster",
      "repo": "https://github.com/你的用户名/你的仓库名",
      "icons": [
        "https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Cloudflare.png",
        "https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Cloudflare.png"
      ]
    }
  ]
}
